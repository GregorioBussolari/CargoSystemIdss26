QActor led context ctxcargosystem {
    State s0 initial {
    	connectToMqttBroker "tcp://mosquitto:1883"
        println("$name | starts - bridge verso PicoW-led su eventTopic") color green
    }
    Goto waiting

    State waiting { }
    Transition t0
        whenMsg startBlink -> handleStart
        whenMsg stopBlink  -> handleStop

    State handleStart {
    	onMsg(startBlink : startBlink(ARG)) {
            // Costruisce la stringa QAk e la spara sul topic del LED
            [# 
               val Freq = payloadArg(0)
               val msg = MsgUtil.buildDispatch(name, "startBlink", "startBlink($Freq)", "picosonar")
               mqtt.publish("picosonar/led", msg.toString())
            #]
        }
    }
    Goto waiting

    State handleStop {
        onMsg(stopBlink : stopBlink(ARG)) {
            // Costruisce la stringa QAk e la spara sul topic del LED
            [# 
               val Freq = payloadArg(0)
               val msg = MsgUtil.buildDispatch(name, "stopBlink", "stopBlink($Freq)", "picosonar")
               mqtt.publish("picosonar/led", msg.toString())
            #]
        }
    }
    Goto waiting
}

QActor sensor context ctxcargosystem {

    [#
    	val DFREE = 80
	    var belowSince = 0L
	    var aboveSince = 0L
	    var restoreSince = 0L
	    var faulted = false
	#]

    State s0 initial {
        connectToMqttBroker  "tcp://mosquitto:1883"
		subscribe "picosonar/data"
        println("$name | starts - Sensore") color cyan
        // Il sensore applicherà logicamente le soglie DFREE per emettere eventi
    }
    Goto monitoring

    State monitoring { }
    Transition t0
        whenEvent sonardata -> handleReading

    State handleReading {
        onMsg(sonardata : sonardata(D)) {
            [#
                val dist = payloadArg(0).toInt()
                val now = System.currentTimeMillis()
            #]
            if [# dist < DFREE/2 #] {
                [# if (belowSince == 0L) belowSince = now; aboveSince = 0L; restoreSince = 0L#]
                if [# belowSince != 0L && (now - belowSince) >= 3000 #] {
                	println("$name | Rilevato container in sensor area") color green
                    emit containerDetected : containerDetected(1)
                    [# belowSince = 0L #]
                }
            } else {
                if [# dist > DFREE #] {
                    [# if (aboveSince == 0L) aboveSince = now; belowSince = 0L; restoreSince = 0L#]
                    if [# aboveSince != 0L && (now - aboveSince) >= 3000 && faulted == false #] {
                    	println("$name | Rilevato sistema compromesso, emetto allarme") color red
                        emit sensorAlarm : sensorAlarm(1)
                        [# faulted = true #]
                    }
                } else {
                    [#
				        if (restoreSince == 0L) restoreSince = now
				        belowSince = 0L
				        aboveSince = 0L
				    #]
				    if [# restoreSince != 0L && (now - restoreSince) >= 3000 && faulted == true #] {
				        println("$name | Guasto risolto") color cyan
				        emit sensorRestored : sensorRestored(1)
				        [# faulted = false; restoreSince = 0L #]
				    }
                }
            }
        }
    }
    Goto monitoring
}

